{
  "name": "MamVibe — New Item Needs Approval",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "item-pending-approval",
        "responseMode": "onReceived",
        "responseCode": 200,
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook: Item Pending",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "item-pending-approval"
    },
    {
      "parameters": {
        "fromEmail": "noreply@mamvibe.com",
        "toEmail": "admin@mamvibe.com",
        "subject": "New item needs approval: {{ $('Webhook: Item Pending').item.json.body.title }}",
        "emailType": "html",
        "html": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"text-align: center; padding: 20px 0;\">\n    <h1 style=\"color: #e91e8c; margin: 0;\">MamVibe Admin</h1>\n  </div>\n  <div style=\"background: #fff; border-radius: 12px; padding: 30px; border: 1px solid #f0f0f0;\">\n    <h2 style=\"color: #e67e22; margin-top: 0;\">New Item Pending Approval</h2>\n    <table style=\"width: 100%; border-collapse: collapse; font-size: 15px; margin: 20px 0;\">\n      <tr>\n        <td style=\"padding: 10px; color: #888; border-bottom: 1px solid #f0f0f0; width: 120px;\">Title</td>\n        <td style=\"padding: 10px; color: #333; font-weight: 600; border-bottom: 1px solid #f0f0f0;\">{{ $('Webhook: Item Pending').item.json.body.title }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; color: #888; border-bottom: 1px solid #f0f0f0;\">Category</td>\n        <td style=\"padding: 10px; color: #333; border-bottom: 1px solid #f0f0f0;\">{{ $('Webhook: Item Pending').item.json.body.category }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; color: #888; border-bottom: 1px solid #f0f0f0;\">Type</td>\n        <td style=\"padding: 10px; color: #333; border-bottom: 1px solid #f0f0f0;\">{{ $('Webhook: Item Pending').item.json.body.listingType }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; color: #888; border-bottom: 1px solid #f0f0f0;\">Price</td>\n        <td style=\"padding: 10px; color: #333; border-bottom: 1px solid #f0f0f0;\">{{ $('Webhook: Item Pending').item.json.body.price || 'Free' }} {{ $('Webhook: Item Pending').item.json.body.price ? 'BGN' : '' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; color: #888; border-bottom: 1px solid #f0f0f0;\">Seller</td>\n        <td style=\"padding: 10px; color: #333; border-bottom: 1px solid #f0f0f0;\">{{ $('Webhook: Item Pending').item.json.body.sellerName }} ({{ $('Webhook: Item Pending').item.json.body.sellerEmail }})</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; color: #888;\">Description</td>\n        <td style=\"padding: 10px; color: #555; font-size: 14px;\">{{ $('Webhook: Item Pending').item.json.body.description }}</td>\n      </tr>\n    </table>\n    <div style=\"text-align: center; margin: 24px 0;\">\n      <a href=\"https://mamvibe.com/admin/items\" style=\"background: #27ae60; color: white; padding: 14px 32px; text-decoration: none; border-radius: 8px; font-size: 16px; font-weight: 600;\">Review & Approve</a>\n    </div>\n  </div>\n  <div style=\"text-align: center; padding: 20px 0; color: #aaa; font-size: 12px;\">&copy; 2026 MamVibe. All rights reserved.</div>\n</div>",
        "options": {}
      },
      "id": "email-admin",
      "name": "Email Admin",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [520, 300],
      "credentials": {
        "smtp": {
          "id": "REPLACE_WITH_SMTP_CREDENTIAL_ID",
          "name": "MamVibe SMTP"
        }
      }
    }
  ],
  "connections": {
    "Webhook: Item Pending": {
      "main": [
        [
          {
            "node": "Email Admin",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    { "name": "MamVibe" },
    { "name": "Admin Alerts" },
    { "name": "Items" }
  ]
}
