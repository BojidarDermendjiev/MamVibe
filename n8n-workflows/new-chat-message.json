{
  "name": "MamVibe — Offline Chat Message",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "new-chat-message",
        "responseMode": "onReceived",
        "responseCode": 200,
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook: New Chat Message",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "new-chat-message"
    },
    {
      "parameters": {
        "fromEmail": "noreply@mamvibe.com",
        "toEmail": "={{ $('Webhook: New Chat Message').item.json.body.receiverEmail }}",
        "subject": "New message from {{ $('Webhook: New Chat Message').item.json.body.senderName }} on MamVibe",
        "emailType": "html",
        "html": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"text-align: center; padding: 20px 0;\">\n    <h1 style=\"color: #e91e8c; margin: 0;\">MamVibe</h1>\n  </div>\n  <div style=\"background: #fff; border-radius: 12px; padding: 30px; border: 1px solid #f0f0f0;\">\n    <h2 style=\"color: #333; margin-top: 0;\">You have a new message \ud83d\udcac</h2>\n    <p style=\"color: #555; font-size: 16px; line-height: 1.6;\"><strong>{{ $('Webhook: New Chat Message').item.json.body.senderName }}</strong> sent you a message while you were offline:</p>\n    <div style=\"background: #f8f4ff; border-left: 4px solid #e91e8c; padding: 16px 20px; margin: 20px 0; border-radius: 0 8px 8px 0;\">\n      <p style=\"color: #444; font-size: 15px; line-height: 1.6; margin: 0; font-style: italic;\">\"{{ $('Webhook: New Chat Message').item.json.body.contentPreview }}\"</p>\n    </div>\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"https://mamvibe.com/chat\" style=\"background: #e91e8c; color: white; padding: 14px 32px; text-decoration: none; border-radius: 8px; font-size: 16px; font-weight: 600;\">Reply Now</a>\n    </div>\n  </div>\n  <div style=\"text-align: center; padding: 20px 0; color: #aaa; font-size: 12px;\">&copy; 2026 MamVibe. All rights reserved.</div>\n</div>",
        "options": {}
      },
      "id": "email-receiver",
      "name": "Email Offline User",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [520, 300],
      "credentials": {
        "smtp": {
          "id": "REPLACE_WITH_SMTP_CREDENTIAL_ID",
          "name": "MamVibe SMTP"
        }
      }
    }
  ],
  "connections": {
    "Webhook: New Chat Message": {
      "main": [
        [
          {
            "node": "Email Offline User",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    { "name": "MamVibe" },
    { "name": "Chat" }
  ]
}
