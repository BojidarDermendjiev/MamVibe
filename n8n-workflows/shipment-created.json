{
  "name": "MamVibe — Shipment Created",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "shipment-created",
        "responseMode": "onReceived",
        "responseCode": 200,
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook: Shipment Created",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "shipment-created"
    },
    {
      "parameters": {
        "fromEmail": "noreply@mamvibe.com",
        "toEmail": "={{ $('Webhook: Shipment Created').item.json.body.buyerEmail }}",
        "subject": "Your order has been shipped! — {{ $('Webhook: Shipment Created').item.json.body.itemTitle }}",
        "emailType": "html",
        "html": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"text-align: center; padding: 20px 0;\">\n    <h1 style=\"color: #e91e8c; margin: 0;\">MamVibe</h1>\n  </div>\n  <div style=\"background: #fff; border-radius: 12px; padding: 30px; border: 1px solid #f0f0f0;\">\n    <h2 style=\"color: #333; margin-top: 0;\">Your order is on its way! \ud83d\udce6</h2>\n    <p style=\"color: #555; font-size: 16px; line-height: 1.6;\">Hi <strong>{{ $('Webhook: Shipment Created').item.json.body.recipientName }}</strong>,</p>\n    <p style=\"color: #555; font-size: 16px; line-height: 1.6;\">The seller has shipped your item. Here are the details:</p>\n    <table style=\"width: 100%; border-collapse: collapse; font-size: 15px; margin: 20px 0;\">\n      <tr>\n        <td style=\"padding: 10px; color: #888; border-bottom: 1px solid #f0f0f0;\">Item</td>\n        <td style=\"padding: 10px; color: #333; font-weight: 600; border-bottom: 1px solid #f0f0f0;\">{{ $('Webhook: Shipment Created').item.json.body.itemTitle }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; color: #888; border-bottom: 1px solid #f0f0f0;\">Courier</td>\n        <td style=\"padding: 10px; color: #333; border-bottom: 1px solid #f0f0f0;\">{{ $('Webhook: Shipment Created').item.json.body.courierProvider }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 10px; color: #888;\">Tracking Number</td>\n        <td style=\"padding: 10px; color: #333; font-weight: 600;\">{{ $('Webhook: Shipment Created').item.json.body.trackingNumber }}</td>\n      </tr>\n    </table>\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"https://mamvibe.com/my-orders\" style=\"background: #e91e8c; color: white; padding: 14px 32px; text-decoration: none; border-radius: 8px; font-size: 16px; font-weight: 600;\">Track Shipment</a>\n    </div>\n  </div>\n  <div style=\"text-align: center; padding: 20px 0; color: #aaa; font-size: 12px;\">&copy; 2026 MamVibe. All rights reserved.</div>\n</div>",
        "options": {}
      },
      "id": "email-buyer",
      "name": "Email Buyer",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [520, 300],
      "credentials": {
        "smtp": {
          "id": "REPLACE_WITH_SMTP_CREDENTIAL_ID",
          "name": "MamVibe SMTP"
        }
      }
    }
  ],
  "connections": {
    "Webhook: Shipment Created": {
      "main": [
        [
          {
            "node": "Email Buyer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
