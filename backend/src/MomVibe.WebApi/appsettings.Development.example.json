{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=MamVibeDb;Username=postgres;Password=YOUR_DB_PASSWORD"
  },
  "JwtSettings": {
    "Secret": "YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG"
  },
  "GoogleAuth": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  },
  "Stripe": {
    "SecretKey": "sk_test_YOUR_STRIPE_SECRET_KEY",
    "PublishableKey": "pk_test_YOUR_STRIPE_PUBLISHABLE_KEY",
    "WebhookSecret": "whsec_YOUR_WEBHOOK_SECRET"
  },
  "Cloudflare": {
    "TurnstileSiteKey": "YOUR_TURNSTILE_SITE_KEY",
    "TurnstileSecretKey": "YOUR_TURNSTILE_SECRET_KEY"
  },
  "Econt": {
    "Username": "YOUR_ECONT_USERNAME",
    "Password": "YOUR_ECONT_PASSWORD"
  },
  "Speedy": {
    "Username": "YOUR_SPEEDY_USERNAME",
    "Password": "YOUR_SPEEDY_PASSWORD"
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_PASSWORD",
    "FromEmail": "noreply@mamvibe.com",
    "FromName": "MamVibe",
    "EnableSsl": true
  },
  "Nekorekten": {
    "ApiKey": "YOUR_NEKOREKTEN_API_KEY",
    "BaseUrl": "https://api.nekorekten.com"
  },
  "AdminSeed": {
    "Enabled": true,
    "Email": "admin@mamvibe.com",
    "Password": "YOUR_ADMIN_PASSWORD",
    "DisplayName": "Admin"
  }
}
