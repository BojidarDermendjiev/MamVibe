{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Grafana.Loki"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/mamvibe-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "app", "value": "mamvibe-api" }
          ],
          "propertiesAsLabels": ["level"]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=MamVibeDb;Username=mamvibe;Password=REPLACE_WITH_SECURE_PASSWORD"
  },
  "FrontendUrl": "http://localhost",
  "JwtSettings": {
    "Secret": "",
    "Issuer": "MamVibe",
    "Audience": "MamVibeApp",
    "AccessTokenExpirationMinutes": 15,
