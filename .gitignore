# ============================================================
# MomVibe — .gitignore (Best Practices)
# ============================================================

# ──────────────────────────────────────────────────────────────
# Backend (.NET)
# ──────────────────────────────────────────────────────────────
backend/**/bin/
backend/**/obj/
backend/.vs/
backend/**/*.user
backend/**/*.suo
backend/**/*.cache
backend/**/appsettings*.Local.json
backend/**/appsettings.Development.json
backend/**/Properties/launchSettings.json

# NuGet
backend/**/packages/
backend/**/*.nupkg

# EF Core migrations snapshot (keep migrations, ignore snapshots if needed)
# backend/**/Migrations/*.Designer.cs

# Build results
backend/**/*.dll
backend/**/*.exe
backend/**/*.pdb

# Publish output
backend/**/publish/

# ──────────────────────────────────────────────────────────────
# User Uploads (NEVER commit to repo)
# ──────────────────────────────────────────────────────────────
backend/**/wwwroot/uploads/demo/
backend/**/wwwroot/uploads/items/
backend/**/wwwroot/uploads/avatars/

# ──────────────────────────────────────────────────────────────
# Frontend (Node / Vite / React)
# ──────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
mobile/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/.vite/
frontend/.eslintcache
frontend/.tsbuildinfo
frontend/*.tsbuildinfo

# ──────────────────────────────────────────────────────────────
# Project Presentation Documents (local only, not for version control)
# ──────────────────────────────────────────────────────────────
*.docx
*.pptx
generate_presentation.py

# ──────────────────────────────────────────────────────────────
# Database Backups (NEVER commit — can contain sensitive data)
# ──────────────────────────────────────────────────────────────
backups/
google-play-service-account.json

# ──────────────────────────────────────────────────────────────
# Secrets & Credentials (NEVER commit)
# ──────────────────────────────────────────────────────────────
**/*.pfx
**/*.key
**/*.pem
**/credentials.json
**/secrets.json
**/.env
**/.env.*
!**/.env.example

# ──────────────────────────────────────────────────────────────
# IDE & Editors
# ──────────────────────────────────────────────────────────────

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains Rider / IntelliJ
.idea/
*.iml

# ──────────────────────────────────────────────────────────────
# OS Generated
# ──────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# ──────────────────────────────────────────────────────────────
# Logs & Temp
# ──────────────────────────────────────────────────────────────
**/*.log
**/logs/
**/tmp/
**/temp/

# ──────────────────────────────────────────────────────────────
# Test & Coverage
# ──────────────────────────────────────────────────────────────
**/TestResults/
**/coverage/
**/*.coverage
**/lcov.info

# ──────────────────────────────────────────────────────────────
# Load Tests
# ──────────────────────────────────────────────────────────────
load-tests/k6/test-users.json
load-tests/reports/
load-tests/nbomber/reports/
load-tests/nbomber/bin/
load-tests/nbomber/obj/

# ──────────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────────
*.swp
*.swo
*.bak
*.orig

# ──────────────────────────────────────────────────────────────
# Claude Code — runtime directories (not for version control)
# ──────────────────────────────────────────────────────────────
.claude/worktrees/
.claude/agent-memory/

# ──────────────────────────────────────────────────────────────
# Playwright / E2E test output
# ──────────────────────────────────────────────────────────────
frontend/test-results/
frontend/playwright-report/

# ──────────────────────────────────────────────────────────────
# Internal docs — kept local only
# ──────────────────────────────────────────────────────────────
CLAUDE.md
DEPLOY.md
*.patch

# ──────────────────────────────────────────────────────────────
# SonarQube analysis output (per-build artifact)
# ──────────────────────────────────────────────────────────────
backend/.sonarqube/
