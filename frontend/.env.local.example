# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Backend proxy targets (dev only — in Docker, Vite dev server is not used)
VITE_API_TARGET=http://localhost:5038
VITE_UPLOADS_TARGET=http://localhost:5038
VITE_HUBS_TARGET=http://localhost:5038

# Cloudflare Turnstile (use the always-pass test key for local dev)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Stripe publishable key (use test key for local dev)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
