<?xml version="1.0" encoding="UTF-8"?>
<!--
  sitemap.xml for MamVibe (https://mamvibe.com)
  Static sitemap covering all public, indexable routes.

  SEO rationale:
  - Item detail pages (/items/:id) are dynamic — a future backend-generated
    sitemap endpoint should extend this file with individual item URLs.
  - Change frequencies and priorities reflect actual crawl priority:
    homepage (daily, 1.0) > browse (daily, 0.9) > community pages (weekly, 0.8).
  - Hreflang: both EN and BG users land on the same URL (language is
    stored client-side). A single canonical URL per page is correct here.
-->
<urlset
  xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml"
>
  <!-- Homepage -->
  <url>
    <loc>https://mamvibe.com/</loc>
    <lastmod>2026-05-10</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
    <xhtml:link rel="alternate" hreflang="en" href="https://mamvibe.com/" />
    <xhtml:link rel="alternate" hreflang="bg" href="https://mamvibe.com/" />
    <xhtml:link rel="alternate" hreflang="x-default" href="https://mamvibe.com/" />
  </url>

  <!-- Browse / marketplace -->
  <url>
    <loc>https://mamvibe.com/browse</loc>
    <lastmod>2026-05-10</lastmod>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
    <xhtml:link rel="alternate" hreflang="en" href="https://mamvibe.com/browse" />
    <xhtml:link rel="alternate" hreflang="bg" href="https://mamvibe.com/browse" />
    <xhtml:link rel="alternate" hreflang="x-default" href="https://mamvibe.com/browse" />
  </url>

  <!-- Doctor reviews community page -->
  <url>
    <loc>https://mamvibe.com/doctor-reviews</loc>
    <lastmod>2026-05-10</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
    <xhtml:link rel="alternate" hreflang="en" href="https://mamvibe.com/doctor-reviews" />
    <xhtml:link rel="alternate" hreflang="bg" href="https://mamvibe.com/doctor-reviews" />
    <xhtml:link rel="alternate" hreflang="x-default" href="https://mamvibe.com/doctor-reviews" />
  </url>

  <!-- Child-friendly places community page -->
  <url>
    <loc>https://mamvibe.com/child-friendly-places</loc>
    <lastmod>2026-05-10</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
    <xhtml:link rel="alternate" hreflang="en" href="https://mamvibe.com/child-friendly-places" />
    <xhtml:link rel="alternate" hreflang="bg" href="https://mamvibe.com/child-friendly-places" />
    <xhtml:link rel="alternate" hreflang="x-default" href="https://mamvibe.com/child-friendly-places" />
  </url>

  <!-- Donation / support page -->
  <url>
    <loc>https://mamvibe.com/donate</loc>
    <lastmod>2026-05-10</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>

  <!--
    NOTE: Individual item pages (/items/:id) are served via a dynamic sitemap
    generated by the backend at /api/sitemap/items — see SitemapController.cs.
    To include them, either:
      (a) Register a sitemap index at /sitemap-index.xml pointing to both this
          file and https://mamvibe.com/api/sitemap/items, or
      (b) Fetch /api/sitemap/items at build time and append URLs here.
  -->
</urlset>
