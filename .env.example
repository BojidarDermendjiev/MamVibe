# ════════════════════════════════════════════════════════════════════
#  MamVibe — Environment Variables Template
#  Copy this file to .env and fill in every value before deploying.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_DB=MamVibeDb
POSTGRES_USER=mamvibe
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_PORT=5432

# ── Public URL ───────────────────────────────────────────────────────
FRONTEND_URL=https://mamvibe.com

# ── JWT ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars

# ── Google OAuth ─────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── Stripe (use sk_live_ / pk_live_ in production) ───────────────────
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
# https://dashboard.stripe.com → Developers → Webhooks → Add endpoint
# Endpoint URL: https://mamvibe.com/api/payments/webhook
# Event to select: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# Wallet top-up webhook secret (separate Stripe webhook endpoint for wallet events)
STRIPE_WALLET_WEBHOOK_SECRET=whsec_YOUR_WALLET_WEBHOOK_SECRET

# ── Cloudflare Turnstile ─────────────────────────────────────────────
# https://dash.cloudflare.com → Turnstile → Add site → mamvibe.com
TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# ── SMTP ─────────────────────────────────────────────────────────────
# Recommended: Brevo (free 300/day) — https://app.brevo.com → SMTP & API
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=YOUR_BREVO_LOGIN_EMAIL
SMTP_PASSWORD=YOUR_BREVO_SMTP_KEY
SMTP_FROM_EMAIL=noreply@mamvibe.com
SMTP_FROM_NAME=MamVibe

# ── Econt courier ────────────────────────────────────────────────────
# Production URL: https://ee.econt.com/services  (NOT the demo URL)
ECONT_USERNAME=YOUR_ECONT_USERNAME
ECONT_PASSWORD=YOUR_ECONT_PASSWORD

# ── Speedy courier ───────────────────────────────────────────────────
SPEEDY_USERNAME=YOUR_SPEEDY_USERNAME
SPEEDY_PASSWORD=YOUR_SPEEDY_PASSWORD

# ── BoxNow courier ───────────────────────────────────────────────────
BOXNOW_API_KEY=YOUR_BOXNOW_API_KEY

# ── TakeANap digital receipts ────────────────────────────────────────
TAKEANAP_API_KEY=YOUR_TAKEANAP_API_KEY
TAKEANAP_API_SECRET=YOUR_TAKEANAP_API_SECRET
TAKEANAP_SHOP_ID=YOUR_TAKEANAP_SHOP_ID

# ── Nekorekten.com ───────────────────────────────────────────────────
NEKOREKTEN_API_KEY=YOUR_NEKOREKTEN_API_KEY

# ── IBAN encryption key (AES-256) ────────────────────────────────────
# Generate: openssl rand -base64 32   (must decode to exactly 32 bytes)
# WARNING: Never change after first deploy — existing IBANs will break.
IBAN_ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes

# ── Admin account (first deploy only — set false after) ──────────────
ADMIN_SEED_ENABLED=true
ADMIN_EMAIL=admin@mamvibe.com
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_DISPLAY_NAME=Admin

# ── n8n automation webhooks ──────────────────────────────────────────
# Self-hosted n8n runs on the same Docker network — API reaches it internally
N8N_BASE_URL=http://n8n:5678/webhook/
N8N_ENABLED=true
# Generate: openssl rand -base64 32
# WARNING: Never change after workflows are saved — stored credentials will break.
N8N_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl
# Credentials for the n8n UI (access via SSH tunnel: ssh -L 5678:n8n:5678 user@server)
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=CHANGE_ME_strong_n8n_password
# HMAC secret for authenticating outbound webhook calls from API → n8n
# Generate: openssl rand -base64 32
N8N_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl
